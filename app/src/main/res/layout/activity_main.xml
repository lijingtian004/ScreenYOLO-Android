<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- 应用标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ScreenYOLO"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- 模型状态显示 -->
    <TextView
        android:id="@+id/tvModelStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="未导入模型"
        android:textSize="16sp"
        android:textColor="@android:color/holo_red_dark"
        android:layout_marginBottom="8dp" />

    <!-- 类别过滤状态显示 -->
    <TextView
        android:id="@+id/tvFilterStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="检测类别: 全部 (80 类)"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="16dp" />

    <!-- 选择模型文件按钮 -->
    <Button
        android:id="@+id/btnPickModel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="选择模型文件 (.tflite)"
        android:layout_marginBottom="12dp" />

    <!-- 类别过滤按钮 -->
    <Button
        android:id="@+id/btnFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="选择检测类别"
        android:layout_marginBottom="24dp" />

    <!-- 开始检测按钮 -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="开始屏幕检测"
        android:enabled="false"
        android:layout_marginBottom="12dp" />

    <!-- 停止检测按钮 -->
    <Button
        android:id="@+id/btnStop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="停止检测"
        android:layout_marginBottom="24dp" />

    <!-- 使用说明 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="使用说明：\n1. 点击“选择模型文件”导入 YOLO TFLite 模型\n2. (可选) 点击“选择检测类别”筛选要检测的物体\n3. 点击“开始屏幕检测”\n4. 授予录屏和悬浮窗权限\n5. 屏幕上会显示检测框"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.3"
        android:background="@android:color/background_light"
        android:padding="12dp" />
</LinearLayout>
